GEMINI_API_KEY=your_gemini_api_key_here

# Client locale for vue-i18n. Supported: "en" (default), "ja".
# Picked up at build/dev time via import.meta.env.VITE_LOCALE.
# VITE_LOCALE=en

# Frontend dev server port (default: 8000 for exe.dev; upstream default is 5173).
# Also used by e2e/playwright.config.ts.
VITE_PORT=8000

# Comma-separated hostnames that Vite's dev server will accept.
# Required when accessing via a reverse proxy (e.g. exe.dev).
# Example: VITE_ALLOWED_HOSTS=myvm.exe.xyz
VITE_ALLOWED_HOSTS=

# CSRF-guard allowlist for cross-origin state-changing requests
# (POST/PUT/PATCH/DELETE). Localhost is always allowed; use this
# to permit a LAN device (e.g. an iPad) or a reverse-proxy host to
# reach `yarn dev`. Comma-separated, verbatim match against the
# `Origin` header — include the scheme and port and do NOT add a
# trailing slash. The literal string `null` is rejected even if
# listed (it's what browsers send for sandboxed iframes / file:// /
# data: pages, which must never be honored as a trusted origin).
# Example:
# MULMOCLAUDE_TRUSTED_ORIGINS=http://192.168.1.42:5173
# ALLOWED_ORIGINS=https://myvm.exe.xyz:8000
ALLOWED_ORIGINS=

# Comma-separated hostnames to allow on ANY port.
# Useful for exe.dev proxies that expose ports 3000-9999.
# Example: ALLOWED_HOSTS=myvm.exe.xyz
ALLOWED_HOSTS=
